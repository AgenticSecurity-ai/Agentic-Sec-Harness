# ============================================================================
# aisec-arxiv-monitor — per-deployment environment overrides
#
# Copy to `.env` (git-ignored) and fill in. These are the deployment-specific
# values; keeping them here keeps the committed files (config.toml) free of
# per-deployment state. An already-exported shell variable still wins over this file.
#
# ONLY non-secret, deployment-specific values belong here. The Discord bot token
# and AWS/Bedrock credentials live in OpenClaw's config / credential chain, never
# in this workspace (security profile B2). Do not put secrets in .env.
# ============================================================================

# Target Discord channel id for posts. REQUIRED — this is the only place it is set.
# (Discord dev mode -> right-click channel -> Copy Channel ID.)
ARXIV_CHANNEL_ID=

# OpenClaw agent id the orchestrator invokes for summarization (default: arxiv).
ARXIV_AGENT_ID=arxiv

# Path/name of the openclaw CLI binary (default: openclaw, i.e. found on PATH).
OPENCLAW_BIN=openclaw
