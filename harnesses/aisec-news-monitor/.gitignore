# Runtime ledger — ships empty, fills on the host. Never commit accumulated ids.
state/seen.json
*.tmp
__pycache__/

# Per-deployment env overrides (channel id, agent id). .env.example is committed.
.env

# Host-specific state OpenClaw creates at registration/run. Not for distribution.
.openclaw/
openclaw-workspace-state.json

# Template files OpenClaw re-scaffolds on `agents add`; not part of this harness.
USER.md
TOOLS.md
HEARTBEAT.md
