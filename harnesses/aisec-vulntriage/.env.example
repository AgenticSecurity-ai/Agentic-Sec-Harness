# ============================================================================
# aisec-vulntriage — per-deployment environment overrides
#
# Copy to `.env` (git-ignored) and fill in. These are the deployment-specific
# values; keeping them here keeps the committed files (config.toml) free of
# per-deployment state. An already-exported shell variable still wins over this file.
#
# ONLY non-secret, deployment-specific values belong here. The Discord bot token
# and AWS credentials live in OpenClaw's config / the host credential chain, never
# in this workspace (security profile B2; read-only IAM role). Do not put secrets
# in .env.
# ============================================================================

# Target Discord channel id for the triage digest. REQUIRED — this is the only
# place it is set. (Discord dev mode -> right-click channel -> Copy Channel ID.)
VULNTRIAGE_CHANNEL_ID=

# OpenClaw agent id the orchestrator invokes for triage (default: aisec-vulntriage).
VULNTRIAGE_AGENT_ID=aisec-vulntriage

# AWS named profile the collector uses for Prowler / feed lookups. Leave empty to
# use the host's default credential chain. MUST resolve to a READ-ONLY role
# (SecurityAudit + ViewOnlyAccess) — this is the harness's outer safety guarantee.
# Recommended: point this at a dedicated read-only profile (e.g. the
# `vulntriage-readonly` profile from README "Appendix — provisioning the
# read-only role", which assumes a SecurityAudit + ViewOnlyAccess + prowler-additions
# role). Example: VULNTRIAGE_AWS_PROFILE=vulntriage-readonly
VULNTRIAGE_AWS_PROFILE=

# Path/name of the openclaw CLI binary (default: openclaw, i.e. found on PATH).
OPENCLAW_BIN=openclaw

# Path/name of the prowler CLI binary (default: prowler, i.e. found on PATH).
# If you installed Prowler into a dedicated venv (recommended for a stable path that
# survives shell/tmp cleanup — see README Prerequisites), point this at that venv's
# binary, e.g. PROWLER_BIN=~/.local/share/aisec-vulntriage/prowler-venv/bin/prowler
PROWLER_BIN=prowler
