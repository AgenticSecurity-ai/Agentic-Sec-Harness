# ============================================================================
# aisec-vulntriage — per-deployment environment overrides
#
# Copy to `.env` (git-ignored) and fill in. These are the deployment-specific
# values; keeping them here keeps the committed files (config.toml) free of
# per-deployment state. An already-exported shell variable still wins over this file.
#
# ONLY non-secret, deployment-specific values belong here. The Discord bot token
# and AWS credentials live in OpenClaw's config / the host credential chain, never
# in this workspace (security profile B2; read-only IAM role). Do not put secrets
# in .env.
# ============================================================================

# Target Discord channel id for the triage digest. REQUIRED — this is the only
# place it is set. (Discord dev mode -> right-click channel -> Copy Channel ID.)
VULNTRIAGE_CHANNEL_ID=

# OpenClaw agent id the orchestrator invokes for triage (default: aisec-vulntriage).
VULNTRIAGE_AGENT_ID=aisec-vulntriage

# AWS named profile the collector uses for Prowler / feed lookups. Leave empty to
# use the host's default credential chain. MUST resolve to a READ-ONLY role
# (SecurityAudit + ViewOnlyAccess) — this is the harness's outer safety guarantee.
# Recommended: point this at a dedicated read-only profile (e.g. the
# `vulntriage-readonly` profile from README "Appendix — provisioning the
# read-only role", which assumes a SecurityAudit + ViewOnlyAccess + prowler-additions
# role). Example: VULNTRIAGE_AWS_PROFILE=vulntriage-readonly
VULNTRIAGE_AWS_PROFILE=

# Path/name of the openclaw CLI binary (default: openclaw, i.e. found on PATH).
OPENCLAW_BIN=openclaw

# Path/name of the prowler CLI binary (default: prowler, i.e. found on PATH).
# If you installed Prowler into a dedicated venv (recommended for a stable path that
# survives shell/tmp cleanup — see README Prerequisites), point this at that venv's
# binary, e.g. PROWLER_BIN=~/.local/share/aisec-vulntriage/prowler-venv/bin/prowler
PROWLER_BIN=prowler

# --- Stage 2 graph context (optional; [graph] in config.toml, off by default) ---
# Turn graph enrichment ON without editing the tracked config default (which stays
# enabled=false). This is a NON-SECRET deployment value, like the channel id above, and
# overrides [graph].enabled when set. Leave unset/commented to use the config default.
# VULNTRIAGE_GRAPH_ENABLED=true
#
# Cartography + Neo4j run OUT-OF-BAND as external tools you operate — the harness
# only QUERIES an already-populated Neo4j (read Cypher over HTTP), it does not run
# Cartography for you. So there is no CARTOGRAPHY_BIN here, and the Neo4j endpoint /
# user / database are non-secret and live in config.toml [graph]. The ONE thing the
# harness needs from the environment is the Neo4j password. See the README
# "Appendix — enabling Stage 2 graph context" for the full setup.
#
# Neo4j password. This IS a secret — read from the environment, not committed. Only
# needed when [graph].enabled = true. Set the SAME value you gave Neo4j at first start
# (docker `NEO4J_AUTH=neo4j/<password>`). Prefer exporting it from the host credential
# chain over storing it in .env; if you do put it here, .env is git-ignored, but treat
# it as sensitive.
# VULNTRIAGE_NEO4J_PASSWORD=

# --- Stage 3 Trivy collector (optional; [trivy] in config.toml, off by default) ---
# Turn the Trivy image/package-CVE collector ON without editing the tracked config
# default (which stays enabled=false). NON-SECRET, like the channel id / graph toggle;
# overrides [trivy].enabled when set. Configure what to scan in config.toml [trivy].targets.
# VULNTRIAGE_TRIVY_ENABLED=true
#
# Path/name of the trivy CLI binary (default: trivy, i.e. found on PATH). Trivy is an
# external tool run like Prowler; you can point this at a small wrapper that runs the
# aquasec/trivy container. See README "Appendix — enabling Stage 3 Trivy".
# TRIVY_BIN=trivy
